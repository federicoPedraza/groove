#!/usr/bin/env bash
set -euo pipefail

# Validates that required Tauri Linux system libraries are actually installed
# by checking for their .so files via ldconfig and pkg-config.
# Reads from linux-deps.json (the single source of truth).

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEPS_JSON="$script_dir/linux-deps.json"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()  { printf "[check-linux-deps] %s\n" "$*"; }
ok()   { printf "${GREEN}  ✓${NC} %s\n" "$*"; }
miss() { printf "${RED}  ✗${NC} %s\n" "$*"; }
hint() { printf "${YELLOW}    → %s${NC}\n" "$*"; }

if [[ "$(uname -s)" != "Linux" ]]; then
  log "not on Linux, skipping"
  exit 0
fi

if ! command -v node >/dev/null 2>&1; then
  log "error: node is required to read linux-deps.json"
  exit 1
fi

# Read check targets from JSON: name|runtime_so|pkg_config|apt_pkg|pacman_pkg|dnf_pkg
check_targets="$(node -e "
  const d = require('$DEPS_JSON');
  for (const lib of d.required_libraries) {
    const apt = lib.packages.apt || '';
    const pac = lib.packages.pacman || '';
    const dnf = lib.packages.dnf || '';
    console.log([lib.name, lib.runtime_so, lib.pkg_config, apt, pac, dnf].join('|'));
  }
")"

missing=0

log "checking Tauri Linux system dependencies..."
echo ""

while IFS='|' read -r name so_name pkg_config apt_pkg pacman_pkg dnf_pkg; do
  found=false

  # Check 1: ldconfig (runtime .so)
  if ldconfig -p 2>/dev/null | grep -q "$so_name"; then
    found=true
  fi

  # Check 2: pkg-config (dev headers)
  if [[ "$found" == false ]] && command -v pkg-config >/dev/null 2>&1; then
    if pkg-config --exists "$pkg_config" 2>/dev/null; then
      found=true
    fi
  fi

  if [[ "$found" == true ]]; then
    ok "$name ($so_name)"
  else
    miss "$name ($so_name) — not found"
    # Detect distro and show install hint
    if command -v pacman >/dev/null 2>&1 && [[ -n "$pacman_pkg" ]]; then
      hint "sudo pacman -S $pacman_pkg"
    elif command -v dnf >/dev/null 2>&1 && [[ -n "$dnf_pkg" ]]; then
      hint "sudo dnf install $dnf_pkg"
    elif command -v apt-get >/dev/null 2>&1 && [[ -n "$apt_pkg" ]]; then
      hint "sudo apt install $apt_pkg"
    fi
    missing=$((missing + 1))
  fi
done <<< "$check_targets"

echo ""

if [[ $missing -gt 0 ]]; then
  printf "[check-linux-deps] ${RED}%d missing dependency(ies)${NC} — install them and re-run this check\n" "$missing"
  log "or run: npm run setup:linux"
  exit 1
else
  printf "[check-linux-deps] ${GREEN}all dependencies present${NC}\n"
  exit 0
fi

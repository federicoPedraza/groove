#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Groove CLI Installer — Linux & macOS
#
# Downloads the latest Groove release from GitHub and installs:
#   1. The desktop app (AppImage/deb on Linux, dmg on macOS)
#   2. The `groove` CLI onto PATH
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/federicoPedraza/groove/main/scripts/install-groove | bash
#   ./scripts/install-groove
#   ./scripts/install-groove --version v0.1.8
#   ./scripts/install-groove --skip-app   # CLI only, skip desktop app
#
# Configuration via env vars:
#   GROOVE_INSTALL_DIR     where the groove CLI is placed  (default: ~/.local/bin)
#   GROOVE_APP_DIR         where the AppImage is placed    (default: ~/.local/share/Groove)
#   GROOVE_REPO            GitHub repo                     (default: federicoPedraza/groove)
#   GROOVE_VERSION         release tag to install          (default: latest)
# ---------------------------------------------------------------------------

VERSION="0.1.8"

GROOVE_REPO="${GROOVE_REPO:-federicoPedraza/groove}"
GROOVE_VERSION="${GROOVE_VERSION:-latest}"
GROOVE_INSTALL_DIR="${GROOVE_INSTALL_DIR:-$HOME/.local/bin}"
GROOVE_APP_DIR="${GROOVE_APP_DIR:-$HOME/.local/share/Groove}"
SKIP_APP="false"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { printf "${CYAN}[groove-installer]${RESET} %s\n" "$*"; }
ok()   { printf "${GREEN}[groove-installer]${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}[groove-installer]${RESET} warn: %s\n" "$*"; }
fail() { printf "${RED}[groove-installer]${RESET} error: %s\n" "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
usage:
  install-groove [options]

options:
  --version <tag>   install a specific release (e.g. v0.1.8)
  --skip-app        install only the CLI, skip the desktop app
  --help            show this help

environment variables:
  GROOVE_INSTALL_DIR   CLI install directory   (default: ~/.local/bin)
  GROOVE_APP_DIR       App install directory   (default: ~/.local/share/Groove)
  GROOVE_REPO          GitHub repository       (default: federicoPedraza/groove)
  GROOVE_VERSION       Release tag             (default: latest)
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      GROOVE_VERSION="${2:-}"
      [[ -z "$GROOVE_VERSION" ]] && fail "--version requires a value"
      shift 2
      ;;
    --skip-app)
      SKIP_APP="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option: $1"
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

detect_platform() {
  local os arch

  os="$(uname -s)"
  arch="$(uname -m)"

  case "$os" in
    Linux)  PLATFORM="linux" ;;
    Darwin) PLATFORM="macos" ;;
    *)      fail "unsupported operating system: $os (use the Windows MSI installer instead)" ;;
  esac

  case "$arch" in
    x86_64|amd64)   ARCH="x86_64" ;;
    aarch64|arm64)   ARCH="aarch64" ;;
    *)               fail "unsupported architecture: $arch" ;;
  esac

  log "detected platform: $PLATFORM ($ARCH)"
}

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

check_runtime_dependencies() {
  local missing=()

  if ! command -v git >/dev/null 2>&1; then
    missing+=("git")
  fi

  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    missing+=("curl or wget")
  fi

  if [[ "$PLATFORM" == "linux" ]]; then
    # Check for webkit2gtk runtime (not -dev, just the runtime library)
    if ! ldconfig -p 2>/dev/null | grep -q "libwebkit2gtk-4.1" && \
       ! dpkg -l 2>/dev/null | grep -q "libwebkit2gtk-4.1" && \
       ! rpm -q 2>/dev/null webkit2gtk4.1 >/dev/null 2>&1; then
      warn "webkit2gtk-4.1 runtime library may not be installed"
      warn "the desktop app requires it — install via your package manager:"
      warn "  Debian/Ubuntu: sudo apt install libwebkit2gtk-4.1-0"
      warn "  Fedora:        sudo dnf install webkit2gtk4.1"
      warn "  Arch:          sudo pacman -S webkit2gtk-4.1"
    fi
  fi

  if [[ ${#missing[@]} -gt 0 ]]; then
    fail "missing required dependencies: ${missing[*]}"
  fi

  ok "runtime dependencies OK"
}

# ---------------------------------------------------------------------------
# Download helpers
# ---------------------------------------------------------------------------

fetch() {
  local url="$1" dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fSL --progress-bar -o "$dest" "$url"
  elif command -v wget >/dev/null 2>&1; then
    wget -q --show-progress -O "$dest" "$url"
  else
    fail "neither curl nor wget is available"
  fi
}

fetch_text() {
  local url="$1"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- "$url"
  else
    fail "neither curl nor wget is available"
  fi
}

# ---------------------------------------------------------------------------
# Release resolution
# ---------------------------------------------------------------------------

resolve_release_tag() {
  if [[ "$GROOVE_VERSION" != "latest" ]]; then
    RELEASE_TAG="$GROOVE_VERSION"
    log "using requested release: $RELEASE_TAG"
    return
  fi

  log "resolving latest release from $GROOVE_REPO"

  local api_url="https://api.github.com/repos/$GROOVE_REPO/releases/latest"
  local response
  response="$(fetch_text "$api_url" 2>/dev/null || true)"

  if [[ -z "$response" ]]; then
    fail "could not fetch release information from GitHub"
  fi

  # Parse tag_name without jq dependency
  RELEASE_TAG="$(printf '%s' "$response" | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')"

  if [[ -z "$RELEASE_TAG" ]]; then
    fail "could not determine latest release tag"
  fi

  log "latest release: $RELEASE_TAG"
}

# ---------------------------------------------------------------------------
# Asset name resolution
# ---------------------------------------------------------------------------

resolve_asset_names() {
  local tag_version="${RELEASE_TAG#v}"

  # CLI sidecar binary
  case "$PLATFORM" in
    linux)
      CLI_ASSET="groove-${ARCH}-unknown-linux-gnu"
      ;;
    macos)
      CLI_ASSET="groove-${ARCH}-apple-darwin"
      ;;
  esac

  # Desktop app bundle
  case "$PLATFORM" in
    linux)
      APPIMAGE_ASSET="Groove_${tag_version}_${ARCH}.AppImage"
      DEB_ASSET="Groove_${tag_version}_${ARCH}.deb"
      ;;
    macos)
      DMG_ASSET="Groove_${tag_version}_${ARCH}.dmg"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# CLI installation
# ---------------------------------------------------------------------------

install_cli() {
  log "installing groove CLI"

  local download_url="https://github.com/$GROOVE_REPO/releases/download/$RELEASE_TAG/$CLI_ASSET"
  local tmp_file
  tmp_file="$(mktemp)"

  log "downloading $CLI_ASSET"
  if ! fetch "$download_url" "$tmp_file"; then
    rm -f "$tmp_file"
    fail "failed to download groove CLI from $download_url"
  fi

  mkdir -p "$GROOVE_INSTALL_DIR"
  mv "$tmp_file" "$GROOVE_INSTALL_DIR/groove"
  chmod +x "$GROOVE_INSTALL_DIR/groove"

  ok "groove CLI installed to $GROOVE_INSTALL_DIR/groove"

  # Check if install dir is on PATH
  if ! echo "$PATH" | tr ':' '\n' | grep -Fxq "$GROOVE_INSTALL_DIR"; then
    warn "$GROOVE_INSTALL_DIR is not on your PATH"
    warn "add this to your shell profile (~/.bashrc, ~/.zshrc, etc.):"
    warn "  export PATH=\"$GROOVE_INSTALL_DIR:\$PATH\""
  fi
}

# ---------------------------------------------------------------------------
# Desktop app installation — Linux
# ---------------------------------------------------------------------------

install_app_linux() {
  log "installing Groove desktop app for Linux"

  # Try AppImage first, fall back to deb
  local download_url="https://github.com/$GROOVE_REPO/releases/download/$RELEASE_TAG/$APPIMAGE_ASSET"
  local tmp_file
  tmp_file="$(mktemp)"

  log "downloading $APPIMAGE_ASSET"
  if fetch "$download_url" "$tmp_file" 2>/dev/null; then
    mkdir -p "$GROOVE_APP_DIR"
    mv "$tmp_file" "$GROOVE_APP_DIR/Groove.AppImage"
    chmod +x "$GROOVE_APP_DIR/Groove.AppImage"
    ok "AppImage installed to $GROOVE_APP_DIR/Groove.AppImage"

    # Create desktop entry
    install_desktop_entry_linux
    return
  fi

  rm -f "$tmp_file"
  log "AppImage not found, trying .deb package"

  download_url="https://github.com/$GROOVE_REPO/releases/download/$RELEASE_TAG/$DEB_ASSET"
  tmp_file="$(mktemp --suffix=.deb)"

  if ! fetch "$download_url" "$tmp_file"; then
    rm -f "$tmp_file"
    warn "could not download desktop app bundle; install it manually from:"
    warn "  https://github.com/$GROOVE_REPO/releases/tag/$RELEASE_TAG"
    return
  fi

  log "installing .deb package (may require sudo)"
  if command -v sudo >/dev/null 2>&1; then
    if sudo dpkg -i "$tmp_file" 2>/dev/null; then
      ok "Groove .deb package installed"
    else
      warn ".deb install failed; trying to fix dependencies"
      sudo apt-get install -f -y 2>/dev/null || true
      if sudo dpkg -i "$tmp_file" 2>/dev/null; then
        ok "Groove .deb package installed (after dependency fix)"
      else
        warn "could not install .deb package; install it manually"
      fi
    fi
  else
    warn "sudo not available; install the .deb package manually: dpkg -i $tmp_file"
  fi

  rm -f "$tmp_file"
}

install_desktop_entry_linux() {
  local desktop_dir="$HOME/.local/share/applications"
  mkdir -p "$desktop_dir"

  cat > "$desktop_dir/groove.desktop" <<DESKTOP
[Desktop Entry]
Name=Groove
Comment=Desktop workspace manager for Git worktrees
Exec=$GROOVE_APP_DIR/Groove.AppImage
Type=Application
Categories=Development;
StartupWMClass=Groove
DESKTOP

  if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database "$desktop_dir" 2>/dev/null || true
  fi

  ok "desktop entry created"
}

# ---------------------------------------------------------------------------
# Desktop app installation — macOS
# ---------------------------------------------------------------------------

install_app_macos() {
  log "installing Groove desktop app for macOS"

  local download_url="https://github.com/$GROOVE_REPO/releases/download/$RELEASE_TAG/$DMG_ASSET"
  local tmp_file
  tmp_file="$(mktemp).dmg"

  log "downloading $DMG_ASSET"
  if ! fetch "$download_url" "$tmp_file"; then
    rm -f "$tmp_file"
    warn "could not download DMG; install it manually from:"
    warn "  https://github.com/$GROOVE_REPO/releases/tag/$RELEASE_TAG"
    return
  fi

  log "mounting DMG and copying Groove.app to /Applications"
  local mount_point
  mount_point="$(mktemp -d)"

  if hdiutil attach "$tmp_file" -mountpoint "$mount_point" -nobrowse -quiet 2>/dev/null; then
    if [[ -d "$mount_point/Groove.app" ]]; then
      rm -rf "/Applications/Groove.app"
      cp -R "$mount_point/Groove.app" "/Applications/Groove.app"
      ok "Groove.app installed to /Applications"
    else
      warn "Groove.app not found in DMG; install manually"
    fi
    hdiutil detach "$mount_point" -quiet 2>/dev/null || true
  else
    warn "could not mount DMG; install it manually: open $tmp_file"
  fi

  rm -rf "$mount_point"
  rm -f "$tmp_file"
}

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

print_summary() {
  echo ""
  printf "${BOLD}${GREEN}Groove $RELEASE_TAG installed successfully${RESET}\n"
  echo ""

  if command -v groove >/dev/null 2>&1; then
    echo "  groove CLI:  $(command -v groove)"
  else
    echo "  groove CLI:  $GROOVE_INSTALL_DIR/groove"
    printf "  ${YELLOW}(add $GROOVE_INSTALL_DIR to your PATH to use 'groove' directly)${RESET}\n"
  fi

  if [[ "$SKIP_APP" == "false" ]]; then
    case "$PLATFORM" in
      linux)
        if [[ -f "$GROOVE_APP_DIR/Groove.AppImage" ]]; then
          echo "  desktop app: $GROOVE_APP_DIR/Groove.AppImage"
        fi
        ;;
      macos)
        if [[ -d "/Applications/Groove.app" ]]; then
          echo "  desktop app: /Applications/Groove.app"
        fi
        ;;
    esac
  fi

  echo ""
  echo "  get started: groove new my-feature"
  echo "  more info:   groove --help"
  echo ""
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  echo ""
  printf "${BOLD}Groove Installer v${VERSION}${RESET}\n"
  echo ""

  detect_platform
  check_runtime_dependencies
  resolve_release_tag
  resolve_asset_names

  install_cli

  if [[ "$SKIP_APP" == "false" ]]; then
    case "$PLATFORM" in
      linux) install_app_linux ;;
      macos) install_app_macos ;;
    esac
  fi

  print_summary
}

main

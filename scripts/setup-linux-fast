#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage:
  setup-linux-fast

quickly installs Linux dev prerequisites for Groove.
EOF
}

log() {
  printf '[setup-linux-fast] %s\n' "$*"
}

warn() {
  printf '[setup-linux-fast] warn: %s\n' "$*"
}

fail() {
  printf '[setup-linux-fast] error: %s\n' "$*" >&2
  exit 1
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 0 ]]; then
  usage
  exit 1
fi

if [[ "$(uname -s)" != "Linux" ]]; then
  fail "this script only supports Linux"
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

ensure_node_and_npm_prerequisite() {
  if command -v node >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
    log "node and npm are already available ($(node -v), npm $(npm -v))"
    return
  fi

  fail "node.js and npm are required but missing. install node.js LTS manually (https://nodejs.org/en/download) and re-run this script"
}

ensure_rust_prerequisite() {
  if [[ -f "$HOME/.cargo/env" ]]; then
    # shellcheck disable=SC1090
    source "$HOME/.cargo/env"
  fi

  if command -v rustc >/dev/null 2>&1 && command -v cargo >/dev/null 2>&1; then
    log "rust is already available ($(rustc --version))"
    return
  fi

  fail "rust is required but missing. install via rustup (https://rustup.rs/) and re-run this script"
}

DEPS_JSON="$script_dir/linux-deps.json"

# Read package list from the single source of truth (linux-deps.json).
# Uses node (already a prerequisite) so we don't need jq on a fresh system.
read_packages_for() {
  local pm="$1"
  node -e "
    const d = require('$DEPS_JSON');
    const libs = d.required_libraries
      .map(l => l.packages['$pm'])
      .filter(Boolean);
    const tools = d.build_toolchains.packages['$pm'] || [];
    console.log([...tools, ...libs].join('\n'));
  "
}

detect_package_manager() {
  if command -v pacman >/dev/null 2>&1; then
    echo "pacman"
  elif command -v dnf >/dev/null 2>&1; then
    echo "dnf"
  elif command -v apt-get >/dev/null 2>&1; then
    echo "apt"
  elif command -v zypper >/dev/null 2>&1; then
    echo "zypper"
  else
    echo "unknown"
  fi
}

get_sudo_cmd() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    echo ""
  elif command -v sudo >/dev/null 2>&1; then
    echo "sudo"
  else
    return 1
  fi
}

install_tauri_linux_deps_best_effort() {
  local pm
  pm="$(detect_package_manager)"

  if [[ "$pm" == "unknown" ]]; then
    warn "no supported package manager found (apt, pacman, dnf, zypper)"
    warn "install these manually: webkit2gtk-4.1, javascriptcoregtk-4.1, libsoup3, libxdo, openssl, appindicator, librsvg"
    return
  fi

  local sudo_cmd
  if ! sudo_cmd="$(get_sudo_cmd)"; then
    warn "need root or sudo to install packages; skipping Tauri Linux deps install"
    return
  fi

  log "detected package manager: $pm"

  local packages=()
  while IFS= read -r pkg; do
    [[ -n "$pkg" ]] && packages+=("$pkg")
  done < <(read_packages_for "$pm")

  if [[ ${#packages[@]} -eq 0 ]]; then
    warn "no packages found for $pm in linux-deps.json"
    return
  fi

  log "installing ${#packages[@]} Tauri Linux system dependencies via $pm"

  case "$pm" in
    apt)
      if ! $sudo_cmd apt-get update; then
        warn "apt update failed; continuing without system dependency installation"
        return
      fi
      $sudo_cmd apt-get install -y "${packages[@]}" || {
        warn "apt install failed; you may need to install Tauri Linux deps manually"
        return
      }
      ;;
    pacman)
      $sudo_cmd pacman -Syu --needed --noconfirm "${packages[@]}" || {
        warn "pacman install failed; you may need to install Tauri Linux deps manually"
        return
      }
      ;;
    dnf)
      $sudo_cmd dnf install -y "${packages[@]}" || {
        warn "dnf install failed; you may need to install Tauri Linux deps manually"
        return
      }
      ;;
    zypper)
      $sudo_cmd zypper install -y "${packages[@]}" || {
        warn "zypper install failed; you may need to install Tauri Linux deps manually"
        return
      }
      ;;
  esac

  log "installed Linux system dependencies"
}

install_project_dependencies() {
  log "installing project dependencies with npm"
  npm install
}

verify_system_deps() {
  log "verifying system dependencies are present"
  if ! "$script_dir/check-linux-deps"; then
    fail "required system dependencies are missing (see above). install them and re-run this script"
  fi
}

run_sanity_check() {
  log "running rust sanity check"
  npm run check:rust
}

run_sidecar_check() {
  log "checking Linux sidecars"
  if ./scripts/check-linux-sidecars; then
    return
  fi

  fail "required Linux sidecar is missing or not executable. place the correct file in src-tauri/binaries/ (for x86_64: groove-x86_64-unknown-linux-gnu, for arm64: groove-aarch64-unknown-linux-gnu) and run: chmod +x src-tauri/binaries/groove-*-unknown-linux-gnu"
}

setup_agent_teams_lite() {
  local atl_dir="${AGENT_TEAMS_LITE_DIR:-$HOME/.local/share/agent-teams-lite}"
  local atl_setup_script="$repo_root/scripts/setup-opencode-atl.sh"

  if [[ ! -f "$atl_setup_script" ]]; then
    warn "ATL setup script not found at $atl_setup_script; skipping Agent Teams Lite provisioning"
    return
  fi

  log "ensuring Agent Teams Lite is available in $atl_dir"
  if ! AGENT_TEAMS_LITE_DIR="$atl_dir" SETUP_OPENCODE_ATL_ALLOW_MISSING_OPENCODE=1 bash "$atl_setup_script" "$repo_root"; then
    warn "Agent Teams Lite provisioning failed; OpenCode status may still warn until ATL is installed"
  fi
}

log "starting Linux fast setup"
ensure_node_and_npm_prerequisite
ensure_rust_prerequisite
install_tauri_linux_deps_best_effort
verify_system_deps

cd "$repo_root"
install_project_dependencies
setup_agent_teams_lite
run_sanity_check
run_sidecar_check

log "setup complete"
log "next step: npm run tauri:dev"
